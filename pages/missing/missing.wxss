/* pages/missing/missing.wxss */
.missing-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #87CEEB 0%, #BBDEFB 50%, #E3F2FD 100%);
}

.page-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  padding: 16rpx 0 4rpx;
  color: #1565C0;
}

.page-subtitle {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #666;
  padding: 0 20rpx;
}

.page-range {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #999;
  padding: 0 20rpx 12rpx;
}

/* 位置选择条 */
.pos-bar {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  margin: 0 16rpx 12rpx;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.05);
}

.pos-item {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.pos-item.active {
  background: #1565C0;
  color: white;
  font-weight: bold;
}

.main-area {
  display: flex;
  height: calc(100vh - 180rpx);
  background: white;
  margin: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.side-bar {
  width: 160rpx !important;
  background: #E8EAF6 !important;
  flex-shrink: 0;
}

.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.table-scroll {
  flex: 1;
  overflow: auto;
}

.table-wrapper {
  min-width: 600rpx;
}

.table-header {
  display: flex;
  background: #E3F2FD;
  border-bottom: 2rpx solid #90CAF9;
  position: sticky;
  top: 0;
  z-index: 10;
}

.th {
  padding: 16rpx 8rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  box-sizing: border-box;
  border-right: 1rpx solid #ddd;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.table-row:nth-child(even) { background: #fafafa; }

.td {
  padding: 14rpx 8rpx;
  text-align: center;
  font-size: 24rpx;
  color: #333;
  box-sizing: border-box;
  border-right: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.number-cell {
  justify-content: center !important;
  gap: 4rpx;
}

.digit {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #E3F2FD;
  border-radius: 6rpx;
  font-weight: bold;
  font-size: 24rpx;
  color: #1565C0;
}

.miss-current {
  color: #E53935;
  font-weight: bold;
}

.miss-max {
  color: #F57C00;
}

/* 信息栏 */
.info-bar {
  padding: 10rpx 16rpx;
  background: #F5F9FF;
  border-bottom: 1rpx solid #E3F2FD;
}

.info-text {
  font-size: 22rpx;
  color: #666;
}

/* 出现次数样式 */
.count-high { color: #1565C0; font-weight: bold; }
.count-low { color: #999; }

/* 高遗漏警告 */
.miss-hot { color: #E53935 !important; font-weight: bold; }

/* pages/bettable/bettable.wxss */
.bet-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4f8, #f0f6f9, #fafcfd);
  padding: 24rpx;
}

/* 引导 */
.bet-guide {
  font-size: 22rpx;
  color: #888;
  padding: 10rpx 16rpx;
  margin-bottom: 14rpx;
  background: #F5F5F5;
  border-radius: 10rpx;
  line-height: 1.6;
}

/* 彩票Tab */
.lottery-tabs {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.l-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 10rpx;
  white-space: nowrap;
}

.l-tab.active {
  background: #1565C0;
  color: white;
  font-weight: bold;
}

/* 投注方式 */
.bet-type-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.type-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.type-tag {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #666;
  border: 2rpx solid transparent;
}

.type-tag.active {
  background: #E3F2FD;
  color: #1565C0;
  border-color: #1565C0;
  font-weight: bold;
}

/* 计算区 */
.calc-area {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.calc-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.calc-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #555;
  flex-shrink: 0;
}

.calc-input {
  width: 180rpx;
  height: 64rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
}

.calc-input.short { width: 120rpx; }

.calc-unit {
  font-size: 24rpx;
  color: #888;
  margin-left: 8rpx;
}

.calc-picker { flex: 1; }

.picker-text {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  background: #fafafa;
}

/* 结果卡片 */
.result-card {
  background: linear-gradient(135deg, #1565C0, #42A5F5);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  color: white;
}

.result-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.result-row:last-child { margin-bottom: 0; }

.result-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.result-value {
  font-size: 36rpx;
  font-weight: bold;
}

.result-value.highlight {
  color: #FFEB3B;
}

.result-value.money {
  color: #FFEB3B;
  font-size: 44rpx;
}

/* 参考表 */
.table-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #1565C0;
  margin-bottom: 16rpx;
}

.ref-table-scroll { background: white; border-radius: 16rpx; overflow: hidden; }

.ref-table { min-width: 500rpx; }

.ref-header {
  display: flex;
  background: #E3F2FD;
}

.ref-header:last-child { border-bottom: none; }

.ref-th {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  border-right: 1rpx solid #ddd;
}

.ref-th:last-child { border-right: none; }

.ref-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.ref-row:nth-child(even) { background: #fafafa; }

.ref-td {
  flex: 1;
  text-align: center;
  padding: 14rpx 8rpx;
  font-size: 24rpx;
  color: #555;
  border-right: 1rpx solid #f0f0f0;
}

.ref-td:last-child { border-right: none; }
.ref-td.price { color: #E53935; font-weight: bold; }

/* 提示卡片 */
.tips-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #F57C00;
  margin-bottom: 16rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  padding-left: 16rpx;
  border-left: 4rpx solid #FFE0B2;
  margin-bottom: 10rpx;
}

/* 复制按钮 */
.copy-bar {
  padding: 16rpx 0;
  text-align: center;
}
.copy-btn {
  display: inline-block;
  padding: 12rpx 32rpx;
  background: #E3F2FD;
  color: #1565C0;
  font-size: 26rpx;
  border-radius: 24rpx;
  border: 1rpx solid #BBDEFB;
  margin: 0;
}
.copy-btn::after { border: none; }

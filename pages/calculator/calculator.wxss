/* pages/calculator/calculator.wxss */
.calc-container{min-height:100vh;background:linear-gradient(180deg,#e8f4f8,#f0f6f9,#fafcfd)}
.page-title{text-align:center;font-size:30rpx;font-weight:bold;padding:18rpx 0;color:#1565C0}
.main-area{display:flex;min-height:calc(100vh - 200rpx);background:#fff;margin:12rpx 16rpx;border-radius:14rpx;overflow:hidden;box-shadow:0 2rpx 16rpx rgba(0,0,0,.06)}
.side-bar{width:150rpx!important;background:#E8EAF6!important;flex-shrink:0}
.check-content{flex:1;padding:16rpx 12rpx;overflow-y:auto}

/* 参考号码 */
.ref-draw{background:#F5F9FF;border:2rpx solid #BBDEFB;border-radius:10rpx;padding:12rpx;margin-bottom:12rpx}
.ref-draw-label{display:block;font-size:20rpx;color:#1565C0;margin-bottom:8rpx}
.ref-draw-nums{display:flex;flex-wrap:wrap;align-items:center;gap:4rpx}
.rball{width:56rpx;height:56rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28rpx;font-weight:bold;color:#fff}
.rball.r{background:#EF5350}.rball.b{background:#42A5F5}.rball.y{background:#FFCA28;color:#333}
.ref-sep{font-size:20rpx;color:#999;margin:0 2rpx}
.ref-nums-text{font-size:18rpx;color:#E91E63;line-height:1.5}

/* KL8开奖小球 */
.ref-ball2{display:flex;align-items:center;justify-content:center;width:40rpx;height:40rpx;font-size:18rpx;font-weight:bold;color:#fff;background:#E91E63;border-radius:8rpx}

/* KL8 */
.kl8-sel{display:flex;align-items:center;justify-content:center;gap:6rpx;margin-bottom:10rpx;font-size:24rpx;color:#555}
.kl8-pk{padding:6rpx 20rpx;border:2rpx solid #1565C0;border-radius:10rpx;font-size:28rpx;font-weight:bold;color:#1565C0}

/* 球号选择区 */
.zone-block{margin-bottom:8rpx}
.zone-title{display:block;font-size:22rpx;font-weight:bold;color:#333;margin-bottom:6rpx;padding:0 4rpx}
.ball-grid{display:flex;flex-wrap:wrap;gap:5rpx;padding:4rpx 0}

/* 球 */
.gball{display:flex;align-items:center;justify-content:center;font-size:26rpx;font-weight:bold;border-radius:50%;transition:all .15s}
.gball.r,.gball.b,.gball.y{width:60rpx;height:60rpx}
.gball.r{background:#FFECEC;color:#EF5350;border:2rpx solid #FFCDD2}
.gball.r.sel{background:#EF5350;color:#fff;border-color:#C62828}
.gball.b{background:#ECF4FF;color:#42A5F5;border:2rpx solid #BBDEFB}
.gball.b.sel{background:#42A5F5;color:#fff;border-color:#1565C0}
.gball.y{background:#FFF8E1;color:#F9A825;border:2rpx solid #FFECB3}
.gball.y.sel{background:#FFCA28;color:#333;border-color:#F9A825}
.gball.p{width:60rpx;height:60rpx;font-size:24rpx;background:#FCE4EC;color:#E91E63;border:2rpx solid #F8BBD0;border-radius:8rpx}
.gball.p.sel{background:#E91E63;color:#fff;border-color:#AD1457}

/* 已选栏 */
.selected-bar{display:flex;align-items:center;flex-wrap:wrap;gap:4rpx;padding:8rpx;margin:8rpx 0;background:#FAFAFA;border-radius:8rpx;min-height:36rpx}
.sel-label{font-size:20rpx;color:#999;margin-right:4rpx}
.sel-ball{display:flex;align-items:center;justify-content:center;width:28rpx;height:28rpx;border-radius:50%;font-size:16rpx;font-weight:bold;color:#fff}
.sel-ball.r{background:#EF5350}.sel-ball.b{background:#42A5F5}.sel-ball.y{background:#FFCA28;color:#333}.sel-ball.p{background:#E91E63;font-size:14rpx;min-width:24rpx;border-radius:6rpx}
.sel-sep{font-size:18rpx;color:#ddd}
.sel-empty{font-size:20rpx;color:#ccc}

/* 数字选择区 */
.digit-block{margin-bottom:10rpx}
.digit-label{display:block;font-size:22rpx;font-weight:bold;color:#333;margin-bottom:4rpx}
.digit-row{display:flex;gap:6rpx}
.dcell{display:flex;align-items:center;justify-content:center;width:120rpx;height:56rpx;font-size:32rpx;font-weight:bold;background:#F5F7FA;border-radius:10rpx;color:#555;border:2rpx solid #E0E6EF}
.dcell.dsel{background:#1565C0;color:#fff;border-color:#0D47A1}

/* 按钮 */
.btn-row{display:flex;gap:12rpx;margin:16rpx 0 8rpx}
.btn-row-s{margin-bottom:12rpx}
.check-btn{flex:1;height:76rpx;line-height:76rpx;background:linear-gradient(135deg,#E53935,#C62828);color:#fff;font-size:30rpx;font-weight:bold;border-radius:38rpx;margin:0;border:none;overflow:visible;padding:0;min-width:180rpx}
.check-btn::after{border:none}
.check-btn.reset-btn{background:linear-gradient(135deg,#42A5F5,#1565C0)}
.random-btn{width:100%;height:60rpx;line-height:60rpx;background:linear-gradient(135deg,#66BB6A,#388E3C);color:#fff;font-size:28rpx;border-radius:30rpx;margin:0;border:none;overflow:visible;text-align:center;display:flex;align-items:center;justify-content:center}
.random-btn::after{border:none}

/* 结果 */
.result-section{margin-top:12rpx}
.result-card{text-align:center;padding:24rpx;border-radius:16rpx;margin-bottom:10rpx}
.result-card.win{background:linear-gradient(135deg,#FFF8E1,#FFECB3);border:2rpx solid #FFD54F}
.result-card.no-win{background:#f5f5f5;border:2rpx solid #e0e0e0}
.result-icon{font-size:60rpx;display:block;margin-bottom:8rpx}
.result-title{font-size:30rpx;font-weight:bold;display:block;margin-bottom:8rpx}
.result-card.win .result-title{color:#E65100}
.result-card.no-win .result-title{color:#999}
.result-prize{font-size:34rpx;font-weight:bold;display:block;color:#E53935}
.result-card.no-win .result-prize{color:#bbb}
.detail-card{background:#fafafa;border-radius:12rpx;padding:16rpx}
.detail-title{font-size:24rpx;font-weight:bold;color:#333;display:block;margin-bottom:10rpx;text-align:center}
.detail-row{display:flex;justify-content:space-between;align-items:center;padding:6rpx 0;border-bottom:1rpx solid #f0f0f0}
.detail-label{font-size:24rpx;color:#666}
.detail-value{font-size:24rpx;font-weight:bold;color:#333}
.detail-value.h{color:#E53935}

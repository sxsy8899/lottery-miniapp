<!--pages/index/index.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在获取开奖数据...</text>
  </view>

  <!-- 加载失败 -->
  <view wx:elif="{{loadError}}" class="error-wrap">
    <text class="error-icon">📡</text>
    <text class="error-text">数据加载失败</text>
    <text class="error-hint">请检查网络连接后重试</text>
    <view class="retry-btn" bindtap="retry">重新加载</view>
  </view>

  <!-- 正常内容 -->
  <block wx:else>
    <view class="welfare-header">
      <text class="logo-text">🎯 中国福利彩票</text>
      <view class="slogan"><text>扶老</text><text>助残</text><text>救孤</text><text>济困</text></view>
    </view>
    <view class="section-title">中国福利彩票开奖结果</view>

    <view wx:for="{{welfareList}}" wx:key="code" class="lottery-card" bindtap="goDetail" data-code="{{item.code}}">
      <image class="lottery-logo" src="{{item.logoImage}}" mode="aspectFill"></image>
      <view class="lottery-info">
        <view class="lottery-name-row">
          <view class="lottery-name-badge">{{item.name}}</view>
          <text class="lottery-schedule">{{item.schedule}}</text>
          <view class="new-badge" wx:if="{{item.data.isNew}}">NEW</view>
          <text class="pool-link">走势 ›</text>
        </view>
        <view class="lottery-period">{{item.data.periodFmt}}　{{item.data.date}}</view>
        <view class="lottery-numbers">
          <block wx:if="{{item.code === 'ssq'}}">
            <view wx:for="{{item.data.reds}}" wx:for-item="ball" wx:key="*this" class="ball ball-red">{{ball}}</view>
            <view class="ball ball-blue">{{item.data.blue}}</view>
          </block>
          <block wx:elif="{{item.code === 'fc3d'}}">
            <view wx:for="{{item.data.numbers}}" wx:for-item="n" wx:key="*this" class="ball ball-yellow">{{n}}</view>
          </block>
          <block wx:elif="{{item.code === 'qlc'}}">
            <view wx:for="{{item.data.numbers}}" wx:for-item="n" wx:key="*this" class="ball ball-red qlc-ball">{{n}}</view>
            <view class="ball ball-yellow qlc-ball">{{item.data.special}}</view>
          </block>
          <block wx:elif="{{item.code === 'kl8'}}">
            <view wx:for="{{item.data.numbers}}" wx:for-item="n" wx:key="*this" class="ball kl8-ball">{{n}}</view>
          </block>
        </view>
      </view>
    </view>

    <view class="footer-bar">数据来源 www.cwl.gov.cn</view>

    <view class="sports-header">
      <text class="logo-text">⚽ 中国体育彩票</text>
      <view class="slogan"><text>责任</text><text>诚信</text><text>团结</text><text>创新</text></view>
    </view>
    <view class="section-title">中国体育彩票开奖结果</view>

    <view wx:for="{{sportsList}}" wx:key="code" class="lottery-card sports-card" bindtap="goDetail" data-code="{{item.code}}">
      <image class="lottery-logo" src="{{item.logoImage}}" mode="aspectFill"></image>
      <view class="lottery-info">
        <view class="lottery-name-row">
          <view class="lottery-name-badge orange">{{item.name}}</view>
          <text class="lottery-schedule">{{item.schedule}}</text>
          <view class="new-badge" wx:if="{{item.data.isNew}}">NEW</view>
          <text class="pool-link">走势 ›</text>
        </view>
        <view class="lottery-period">{{item.data.periodFmt}}　{{item.data.date}}</view>
        <view class="lottery-numbers">
          <block wx:if="{{item.code === 'dlt'}}">
            <view wx:for="{{item.data.front}}" wx:for-item="ball" wx:key="*this" class="ball ball-red">{{ball}}</view>
            <view wx:for="{{item.data.back}}" wx:for-item="b" wx:key="*this" class="ball ball-yellow">{{b}}</view>
          </block>
          <block wx:else>
            <view wx:for="{{item.data.numbers}}" wx:for-item="n" wx:key="*this" class="ball ball-purple">{{n}}</view>
          </block>
        </view>
      </view>
    </view>

    <view class="footer-bar">数据来源 www.lottery.gov.cn</view>
    <view class="update-bar">{{updateTime}}</view>
    <view style="height:120rpx;"></view>
  </block>
</view>
